@startuml
skinparam classAttributeIconSize 0

package "API Layer" {
  class MetricsController {
    +getMetrics(): MetricsResponse
  }
}

package "Service Layer" {
  class MetricsService {
    +getMetrics(user: AuthUser): MetricsResponse
    -factory: MetricsStrategyFactory
  }

  class MetricsStrategyFactory {
    +getStrategy(role: UserRole): MetricsStrategy
  }
}

package "Strategy Layer" {
  interface MetricsStrategy {
    +computeSummary(): MetricsSummary
    +computeSeries(granularity: Granularity, period: Period): List<MetricsSeriesPoint>
    +getRole(): UserRole
  }

  class EditorMetricsStrategy implements MetricsStrategy {
    -articleRepo: ArticleRepository
    +computeSummary(): EditorSummary
    +computeSeries(): List<EditorSeriesPoint>
  }

  class TourOperatorMetricsStrategy implements MetricsStrategy {
    -tourRepo: TourRepository
    -bookingRepo: BookingRepository
    +computeSummary(): TourOperatorSummary
    +computeSeries(): List<TourOperatorSeriesPoint>
  }

  class AdminMetricsStrategy implements MetricsStrategy {
    -userRepo: UserRepository
    -tourRepo: TourRepository
    +computeSummary(): AdminSummary
    +computeSeries(): List<AdminSeriesPoint>
  }
}

package "Data Layer" {
  class ArticleRepository
  class TourRepository
  class BookingRepository
  class UserRepository
}

package "DTOs / Response Models" {
  class MetricsResponse {
    +meta: MetricsMeta
    +summary: MetricsSummary
    +series: List<MetricsSeriesPoint>
  }

  class MetricsMeta
  class MetricsSummary
  class MetricsSeriesPoint
}

MetricsController --> MetricsService
MetricsService --> MetricsStrategyFactory
MetricsStrategyFactory --> MetricsStrategy
MetricsStrategy <|-- EditorMetricsStrategy
MetricsStrategy <|-- TourOperatorMetricsStrategy
MetricsStrategy <|-- AdminMetricsStrategy

EditorMetricsStrategy --> ArticleRepository
TourOperatorMetricsStrategy --> TourRepository
TourOperatorMetricsStrategy --> BookingRepository
AdminMetricsStrategy --> UserRepository
AdminMetricsStrategy --> TourRepository

MetricsResponse *--> MetricsMeta
MetricsResponse *--> MetricsSummary
MetricsResponse *--> MetricsSeriesPoint

note right of MetricsStrategy
  Strategy Pattern:
  Each role has its own
  computation logic
end note

note bottom of MetricsService
  Single entry point for /metrics
  Role-based response shaping
end note
@enduml